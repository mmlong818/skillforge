# SkillForge Web App - Environment Variables
# Copy this file to .env and fill in the values

# ============================================================
# Database (Required)
# ============================================================
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@host:3306/skillforge

# ============================================================
# LLM API (Required)
# ============================================================
# The app uses OpenAI-compatible API format.
# You can use any provider that supports the /v1/chat/completions endpoint.
#
# Option 1: OpenAI
#   BUILT_IN_FORGE_API_URL=https://api.openai.com/v1/chat/completions
#   BUILT_IN_FORGE_API_KEY=sk-your-openai-key
#
# Option 2: Anthropic (via OpenAI-compatible proxy)
#   BUILT_IN_FORGE_API_URL=https://your-proxy/v1/chat/completions
#   BUILT_IN_FORGE_API_KEY=your-key
#
# Option 3: Any OpenAI-compatible provider (DeepSeek, Together, etc.)
#   BUILT_IN_FORGE_API_URL=https://api.deepseek.com/v1/chat/completions
#   BUILT_IN_FORGE_API_KEY=your-key
#
BUILT_IN_FORGE_API_URL=https://api.openai.com/v1/chat/completions
BUILT_IN_FORGE_API_KEY=sk-your-api-key-here

# ============================================================
# Authentication (Optional - for multi-user mode)
# ============================================================
# AUTH_MODE controls how users are authenticated.
# - oauth (default): use the original Manus OAuth + session flow
# - local: local development only; auto-sign in a fixed local user
AUTH_MODE=oauth
# For Manus OAuth integration:
JWT_SECRET=your-random-jwt-secret-at-least-32-chars
VITE_APP_ID=your-oauth-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im/login

# Owner info (used for admin features)
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=your-name

# ============================================================
# Server (Optional)
# ============================================================
# Port to run the server on (default: 3000)
PORT=3000
NODE_ENV=development
